{
  "name": "locomotive-furniture",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-seo.mjs",
    "build": "vue-tsc -b && vite build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint src && prettier --check \"src/**/*.{ts,vue,css}\"",
    "lint:fix": "eslint src --fix && prettier --write \"src/**/*.{ts,vue,css}\"",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "e2e": "echo 'E2E: install Cypress separately — see docs/DEPLOYMENT.md'",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "gsap": "^3.15.0",
    "locomotive-scroll": "^5.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}

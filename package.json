{
  "name": "locomotive-furniture",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "prebuild": "node scripts/generate-seo.mjs",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "nuxt typecheck",
    "lint": "eslint src && prettier --check \"src/**/*.{ts,vue,css}\"",
    "lint:fix": "eslint src --fix && prettier --write \"src/**/*.{ts,vue,css}\"",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "check:changed": "node scripts/check-changed.mjs",
    "vercel-build": "node scripts/vercel-build.mjs",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "deploy:docs": "vercel --prod --project locomotive-furniture-docs",
    "deploy:all": "npm run deploy && npm run deploy:docs",
    "build:e2e": "NUXT_PUBLIC_ENABLE_SMOOTH_SCROLL=false NUXT_PUBLIC_ENABLE_PARALLAX=false NUXT_PUBLIC_COMMERCE_PROVIDER=mock NUXT_PUBLIC_API_BASE_URL= NUXT_PUBLIC_ENABLE_ANALYTICS=false npm run build",
    "e2e": "npm run build:e2e && playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "gsap": "^3.15.0",
    "locomotive-scroll": "^5.0.1",
    "nuxt": "^3.17.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^10.0.8",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@nuxtjs/i18n": "^9.5.0",
    "@pinia/nuxt": "^0.11.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "commander": "^13.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}

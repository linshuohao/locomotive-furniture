# Copy to .env.development / .env.production and adjust values

VITE_APP_TITLE=Atelier Furniture
VITE_APP_ENV=development
VITE_SITE_URL=http://localhost:5173

# Motion
VITE_ENABLE_SMOOTH_SCROLL=true
VITE_ENABLE_PARALLAX=true
VITE_ENABLE_ANALYTICS=false

# Commerce — mock uses local catalog; http calls VITE_API_BASE_URL
VITE_COMMERCE_PROVIDER=mock
VITE_API_BASE_URL=

# Payment — reserved for Phase 2 (stripe | shopify | none)
VITE_PAYMENT_PROVIDER=none

# Optional CDN prefix for static assets
VITE_CDN_BASE=

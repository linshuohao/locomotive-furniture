# Copy to .env.development / .env.production and adjust values

NUXT_PUBLIC_APP_TITLE=Atelier Furniture
NUXT_PUBLIC_APP_ENV=development
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Motion
NUXT_PUBLIC_ENABLE_SMOOTH_SCROLL=true
NUXT_PUBLIC_ENABLE_PARALLAX=true
NUXT_PUBLIC_ENABLE_ANALYTICS=false

# Commerce — mock uses local catalog; http calls NUXT_PUBLIC_API_BASE_URL
NUXT_PUBLIC_COMMERCE_PROVIDER=mock
NUXT_PUBLIC_API_BASE_URL=

# Payment — reserved for Phase 2 (stripe | shopify | none)
NUXT_PUBLIC_PAYMENT_PROVIDER=none

# Optional CDN prefix for static assets
NUXT_PUBLIC_CDN_BASE=
